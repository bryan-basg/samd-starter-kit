# .env.example — {{PROJECT_NAME}}
# REGLA: toda var nueva leída en código (config/Settings u os.getenv) DEBE estar acá,
# con un comentario SaMD-aware. El onboarding de devs no se rompe en silencio.
# En PRODUCCIÓN, los secretos viven en el gestor de secretos, NO en este archivo.

# --- Identidad / Auth ---
AUTH_PROVIDER=                 # proveedor de identidad (emite el token con el claim user_id)

# --- Cifrado (claves SEPARADAS, nunca reusar una para la otra) ---
ENCRYPTION_KEY=               # AES-256-GCM para PII/PHI en reposo. Prod: gestor de secretos/KMS.
SECRET_KEY=                   # firma de sesión. Distinta de ENCRYPTION_KEY.

# --- Base de datos ---
DATABASE_URL=                 # cadena de conexión. Dev local puede usar SQLite.

# --- Plataforma cloud ---
# (env vars de prod viven en el gestor de secretos; documentá acá cuáles existen)

# --- Flags ---
TESTING=False
ENABLE_INTERNAL_SCHEDULER=false   # en prod, el scheduling lo hace un cron gestionado externo
